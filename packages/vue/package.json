{
  "name": "@domograph/vue",
  "version": "0.0.2",
  "description": "Vue 3 plugin for domograph — drop-in live DOM-node-count debug overlay.",
  "keywords": [
    "chart",
    "debug",
    "dom",
    "overlay",
    "plugin",
    "vue",
    "vue3"
  ],
  "homepage": "https://github.com/thyngster/domograph#readme",
  "bugs": {
    "url": "https://github.com/thyngster/domograph/issues"
  },
  "license": "MIT",
  "author": "David Vallejo <david@analytics-debugger.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thyngster/domograph.git",
    "directory": "packages/vue"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "domograph": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "7.0.0-dev.20260328.1",
    "bumpp": "^11.0.1",
    "typescript": "^6.0.2",
    "vite-plus": "^0.1.14",
    "vue": "^3.5.0"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "packageManager": "bun@1.3.13"
}
